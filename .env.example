# .env.example — Variables d'environnement requises
# Copiez ce fichier en .env et remplissez vos clés API
# Le fichier .env est gitignore et ne doit JAMAIS être commité

# ── Clé secrète Flask (obligatoire en production) ────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=changez_moi_en_production_valeur_aleatoire_longue

# ── NewsAPI ───────────────────────────────────────────────
# Inscription gratuite : https://newsapi.org/
NEWS_API_KEY=votre_cle_newsapi_ici

# ── Groq (LLM) ───────────────────────────────────────────
# Console Groq : https://console.groq.com/
# Modèle utilisé : llama-3.3-70b-versatile
GROQ_API_KEY=votre_cle_groq_ici

# ── Supabase (persistance comptes + watchlist) ───────────
# Laisser vide → fichiers locaux (dev sans Supabase)
# Project Settings → API → Project URL
SUPABASE_URL=
# Project Settings → API → anon public key
SUPABASE_KEY=

# ── Finnhub (données boursières) ─────────────────────────
# Compte gratuit : https://finnhub.io/ → Dashboard → API Key
# 60 appels/min, fonctionne sur Render et tout cloud
FINNHUB_API_KEY=votre_cle_finnhub_ici

# ── SMTP (alertes email) ─────────────────────────────────
# Optionnel : uniquement si les alertes email sont activées
SMTP_PASSWORD=votre_mot_de_passe_smtp_ici
